{
  "name": "ecommerce-demo-store-playwright-tests",
  "version": "1.0.0",
  "description": "End-to-end Playwright + TypeScript test suite for the TestDino Ecommerce Demo Store (https://storedemo.testdino.com). Covers auth, profile, cart, checkout, orders, wishlist and reviews using the Page Object Model.",
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:chromium": "playwright test --project=chromium",
    "test:report": "playwright show-report",
    "merge-reports": "playwright merge-reports --config=playwright.config.ts ./all-blob-reports",
    "report:upload": "tdpw upload ./playwright-report --upload-html",
    "codegen": "playwright codegen https://storedemo.testdino.com/",
    "install:browsers": "playwright install --with-deps"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^24.3.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  },
  "overrides": {
    "chalk": "^4.1.2",
    "commander": "^12.1.0",
    "ora": "^5.4.1",
    "figures": "^3.2.0"
  },
  "dependencies": {
    "dotenv": "^17.2.2",
    "playwright": "^1.60.0",
    "tdpw": "^1.0.38"
  }
}
