# ─────────────────────────────────────────────────────────────
# Environment variables for the Ecommerce Demo Store test suite
# Copy this file to `.env` and fill in real values before running.
#   cp .env.example .env
# `.env` is git-ignored and loaded by dotenv in tests/ecommerce.spec.ts.
# Target site: https://storedemo.testdino.com
# ─────────────────────────────────────────────────────────────

# Primary test account (login / logout, cart, checkout, orders, reviews)
USERNAME=your-test-email@example.com
PASSWORD=your-password

# Secondary account used only by the "change password" test
# (so the password mutation never touches the primary account)
USERNAME1=your-second-test-email@example.com
NEW_PASSWORD=your-temporary-new-password

# Shipping address used by the multi-order checkout journey
# (prefix S = "Shipping")
SFIRST_NAME=Test
SCITY=New York
SSTATE=New York
SSTREET_ADD=123 Main St
SZIP_CODE=10001
SCOUNTRY=United States

# TestDino CLI upload token — used by `npm run report:upload` (tdpw reads TESTDINO_TOKEN).
# Get yours from https://testdino.com. In CI, store it as a GitHub Actions secret instead.
TESTDINO_TOKEN=trx_production_your_token_here
